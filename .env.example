VITE_AIRIFICA_BRAND_NAME=Airifica
VITE_AIRIFICA_PUBLIC_APP_URL=
# Optional frontend-side admin wallet hint for showing the dashboard entry.
# Backend AIRIFICA_ADMIN_WALLETS remains authoritative for real access.
VITE_AIRIFICA_ADMIN_WALLETS=
VITE_AIR3_TELEGRAM_BOT_USERNAME=
VITE_AIR3_ELIZA_BASE_URL=
VITE_AIR3_RUNTIME_BASE_URL=
VITE_AIR3_SERVICE_API_URL=
VITE_AIRIFICA_AVATAR_MODEL_URL=
VITE_AIR3_DEFAULT_MARKET=BTC
VITE_AIR3_PACIFICA_TRADE_BASE_URL=https://app.pacifica.fi/trade
VITE_AIR3_PACIFICA_PORTFOLIO_BASE_URL=https://app.pacifica.fi/portfolio
VITE_AIR3_PACIFICA_DEPOSIT_BASE_URL=https://app.pacifica.fi/portfolio
VITE_AIR3_PACIFICA_WITHDRAW_BASE_URL=https://app.pacifica.fi/portfolio
VITE_AIR3_JUPITER_SWAP_BASE_URL=https://jup.ag/swap
VITE_AIR3_JUPITER_API_BASE_URL=/api/jupiter
VITE_AIR3_JUPITER_TRIGGER_API_BASE_URL=/api/jupiter-trigger
VITE_AIR3_JUPITER_TRIGGER_ENABLED=true
VITE_AIR3_JUPITER_TRIGGER_ORDER_TTL_MS=2592000000
VITE_AIR3_JUPITER_TRIGGER_MIN_ORDER_USD=10
VITE_AIR3_JUPITER_TRIGGER_TP_SLIPPAGE_BPS=100
VITE_AIR3_JUPITER_TRIGGER_SL_SLIPPAGE_BPS=200
VITE_AIR3_JUPITER_INPUT_MINT=EPjFWdd5AufqSSqeM2qN1xzybapC8G4wEGGkZwyTDt1v
VITE_AIR3_JUPITER_INPUT_SYMBOL=USDC
VITE_AIR3_JUPITER_INPUT_DECIMALS=6
VITE_AIR3_JUPITER_REFERRAL_ACCOUNT=
VITE_AIR3_JUPITER_REFERRAL_FEE_BPS=0
# If enabled symbols are set, only those output symbols apply referral fees.
VITE_AIR3_JUPITER_REFERRAL_ENABLED_SYMBOLS=
# By default fees are suppressed on majors/stables to avoid degrading execution quality.
VITE_AIR3_JUPITER_REFERRAL_DISABLED_SYMBOLS=SOL,BTC,ETH,USDC,USDT,JUP,JLP,JUPSOL
VITE_AIR3_PACIFICA_BUILDER_CODE=AIRewardrop
VITE_AIR3_PACIFICA_REFERRAL_CODE=AIRewardrop
VITE_AIR3_PACIFICA_BUILDER_MAX_FEE_RATE=0.001
VITE_AIR3_EMBED_ALLOWED_ORIGIN=
VITE_AIR3_TTS_PROVIDER=openai-compatible
VITE_AIR3_TTS_BASE_URL=
VITE_AIR3_TTS_DEV_PROXY_URL=http://127.0.0.1:4041
AIRIFICA_TTS_PROXY_TARGET_URL=http://192.168.178.87:8880
AIRIFICA_TTS_PROXY_TARGET_PATH=/v1/audio/speech
AIRIFICA_TTS_PROXY_CAPTION_PATH=/dev/captioned_speech
AIRIFICA_TTS_PROXY_PHONEME_PATH=/dev/phonemize
VITE_AIR3_TTS_SPEECH_PATH=/api/tts
VITE_AIR3_TTS_CAPTION_PATH=/api/tts/captioned
VITE_AIR3_TTS_PHONEME_PATH=/api/tts/phonemes
VITE_AIR3_TTS_MODEL=tts-1
VITE_AIR3_TTS_VOICE=af_heart
VITE_AIR3_TTS_VOICE_MODE=predefined
VITE_AIR3_TTS_PREDEFINED_VOICE_ID=
VITE_AIR3_TTS_API_KEY=
VITE_AIR3_TTS_RESPONSE_FORMAT=wav
VITE_AIR3_TTS_STREAM_ENABLED=true
VITE_AIR3_TTS_STREAM_FORMAT=pcm
VITE_AIR3_TTS_STREAM_SAMPLE_RATE=24000
VITE_AIR3_TTS_STREAM_CHUNK_MS=180
VITE_AIR3_TTS_PHONEME_LANGUAGE=a
VITE_AIR3_TTS_SPLIT_TEXT=true
VITE_AIR3_TTS_CHUNK_SIZE=120
VITE_AIR3_TTS_SPEED_FACTOR=1
VITE_AIR3_TTS_SEED=

# Speech-to-text fallback
# auto: use browser STT where reliable, otherwise server
# browser: force Web Speech API only
# server: force sherpa-onnx websocket only
VITE_AIR3_STT_PROVIDER=auto
# Prefer a same-origin websocket path in production to avoid mixed-content issues.
VITE_AIR3_STT_WS_URL=/api/stt/ws
VITE_AIR3_STT_CONNECT_TIMEOUT_MS=8000
VITE_AIR3_STT_RESPONSE_TIMEOUT_MS=20000
VITE_AIR3_STT_MIN_UTTERANCE_MS=200
# Dev/bridge-only upstream target for the same-origin websocket proxy.
AIRIFICA_STT_PROXY_TARGET_WS_URL=ws://192.168.178.87:6006
AIRIFICA_JUPITER_API_BASE_URL=https://api.jup.ag/swap/v2
AIRIFICA_JUPITER_TRIGGER_API_BASE_URL=https://api.jup.ag/trigger/v2
AIRIFICA_JUPITER_API_KEY=

VITE_AIR3_STAGE_BRIGHTNESS=0.80
VITE_AIR3_STAGE_CONTRAST=1.05
VITE_AIR3_STAGE_SATURATION=1.50
VITE_AIR3_STAGE_EXPOSURE=0.80
VITE_AIR3_STAGE_AMBIENT_INTENSITY=0.00
VITE_AIR3_STAGE_HEMISPHERE_INTENSITY=0.50
VITE_AIR3_STAGE_KEY_INTENSITY=2.60
VITE_AIR3_STAGE_RIM_INTENSITY=0.00
VITE_AIR3_STAGE_FILL_INTENSITY=1.20

# Optional local mirror of backend-only AIR3 settings.
# These do not reach the browser unless prefixed with VITE_.
AIRI3_AUTH_SECRET=
AIRI3_ENCRYPTION_KEY=
