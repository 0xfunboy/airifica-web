[Unit]
Description=Airifica port bridge
After=network.target

[Service]
Type=simple
User=funboy
Group=funboy
WorkingDirectory=/home/funboy/airifica-stack/airifica-web
Environment=HOME=/home/funboy
ExecStart=/home/funboy/.nvm/versions/node/v24.9.0/bin/node /home/funboy/airifica-stack/airifica-web/scripts/port-bridge.mjs
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
